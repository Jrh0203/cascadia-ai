<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.johnherrick.cascadia.v3-dashboard-watch</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/johnherrick/cascadia/.venv/bin/python</string>
    <string>tools/v3_campaign.py</string>
    <string>refresh-dashboard</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/johnherrick/cascadia</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONDONTWRITEBYTECODE</key>
    <string>1</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>10</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>/tmp/cascadia-v3-dashboard.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/cascadia-v3-dashboard.stderr.log</string>
</dict>
</plist>
